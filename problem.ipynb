    "    op=[]\n",
    "    \n",
    "    res =0\n",
    "    for i in lst:\n",
    "        while(i!=0):\n",
    "            res +=i%10\n",
    "            i=i//10\n",
    "        res+=i\n",
    "        \n",
    "    if (res %2==0):\n",
    "        op.append(i)\n",
    "        \n",
    "push_even([12,4,33,57,88])\n",
